{
  "name": "@sprint-mode/sm-ui",
  "version": "1.0.1",
  "description": "Sprint Mode shared platform UI \u2014 components, design tokens, auth helpers, login",
  "repository": {
    "type": "git",
    "url": "https://github.com/sprint-mode/sm-ui"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/src/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./css": "./src/index.css",
    "./css/shell": "./src/shell.css",
    "./css/components": "./src/components.css",
    "./brands": "./brands/"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6"
  },
  "license": "UNLICENSED",
  "private": false,
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "lint": "eslint src/",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "build:standalone": "vite build --config vite.config.lib.ts",
    "build": "vite build --config vite.config.build.ts && node scripts/fix-dts-paths.js"
  },
  "type": "module",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "src/index.css",
    "src/shell.css",
    "src/components.css",
    "src/tokens.css",
    "src/Icons.d.ts",
    "brands"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
